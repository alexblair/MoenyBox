generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AccountType {
  BANK
  CREDIT_CARD
  VIRTUAL
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  color     String     @default("#6366f1")
  icon      String?
  note      String?
  sortOrder Int        @default(0)
  userId    Int        @default(1)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions         Transaction[] @relation("TransactionCategory")
  templateTransactions TransactionTemplate[] @relation("TemplateCategory")

  @@index([userId])
  @@map("categories")
}

model Account {
  id        Int         @id @default(autoincrement())
  name      String
  type      AccountType @default(VIRTUAL)
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  currency  String      @default("CNY")
  icon      String?
  sortOrder Int         @default(0)
  userId    Int         @default(1)
  archived  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  transactions         Transaction[] @relation("TransactionAccount")
  transferTransactions Transaction[] @relation("TransactionToAccount")
  templateTransactions TransactionTemplate[] @relation("TemplateAccount")
  templateToTransactions TransactionTemplate[] @relation("TemplateToAccount")
  groupMembers          AccountGroupMember[]

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

model AccountGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  color       String   @default("#6366f1")
  sortOrder   Int      @default(0)
  userId      Int      @default(1)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members AccountGroupMember[]

  @@unique([userId, name])
  @@index([userId])
  @@map("account_groups")
}

model AccountGroupMember {
  accountId Int
  account   Account @relation(fields: [accountId], references: [id])
  groupId   Int
  group     AccountGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  @@id([accountId, groupId])
  @@index([accountId])
  @@index([groupId])
  @@map("account_group_members")
}

model Transaction {
  id         Int             @id @default(autoincrement())
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  categoryId Int?
  category   Category?       @relation("TransactionCategory", fields: [categoryId], references: [id])
  accountId  Int
  account    Account         @relation("TransactionAccount", fields: [accountId], references: [id])
  toAccountId Int?
  toAccount  Account?        @relation("TransactionToAccount", fields: [toAccountId], references: [id])
  note       String?
  dateTime   DateTime        @default(now())
  userId     Int             @default(1)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  attachments TransactionAttachment[]

  @@index([accountId])
  @@index([categoryId])
  @@index([dateTime])
  @@index([type])
  @@index([userId])
  @@map("transactions")
}

model Attachment {
  id        Int         @id @default(autoincrement())
  hash      String      @db.VarChar(64)
  filename  String
  filepath  String
  mimeType  String
  size      Int         @default(0)
  userId    Int         @default(1)
  createdAt DateTime    @default(now())

  transactions TransactionAttachment[]

  @@unique([userId, hash])
  @@index([userId])
  @@map("attachments")
}

model TransactionAttachment {
  transactionId  Int
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  attachmentId   Int
  attachment     Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@id([transactionId, attachmentId])
  @@index([transactionId])
  @@index([attachmentId])
  @@map("transaction_attachments")
}

model TransactionTemplate {
  id          Int             @id @default(autoincrement())
  name        String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  categoryId  Int?
  category    Category?       @relation("TemplateCategory", fields: [categoryId], references: [id])
  accountId   Int
  account     Account         @relation("TemplateAccount", fields: [accountId], references: [id])
  toAccountId Int?
  toAccount   Account?        @relation("TemplateToAccount", fields: [toAccountId], references: [id])
  note        String?
  sortOrder   Int             @default(0)
  parentId    Int?
  parent      TransactionTemplate? @relation("TemplateHierarchy", fields: [parentId], references: [id])
  children    TransactionTemplate[] @relation("TemplateHierarchy")
  active      Boolean         @default(true)
  userId      Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([parentId])
  @@index([active])
  @@index([userId])
  @@map("transaction_templates")
}

model RuleGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  mode        String   @default("ALL")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  scenarios   String   @default("[\"IMPORT\",\"MANUAL\"]")
  userId      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules Rule[]

  @@index([userId])
  @@map("rule_groups")
}

model Rule {
  id            Int      @id @default(autoincrement())
  groupId       Int
  group         RuleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  conditionMode String   @default("ALL")
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conditions RuleCondition[]
  actions    RuleAction[]

  @@index([groupId])
  @@map("rules")
}

model RuleCondition {
  id        Int      @id @default(autoincrement())
  ruleId    Int
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  field     String
  operator  String
  value     String
  createdAt DateTime @default(now())

  @@index([ruleId])
  @@map("rule_conditions")
}

model RuleAction {
  id        Int      @id @default(autoincrement())
  ruleId    Int
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  field     String
  value     String
  createdAt DateTime @default(now())

  @@index([ruleId])
  @@map("rule_actions")
}

model AccountPermission {
  id        Int      @id @default(autoincrement())
  accountId Int?
  groupId   Int?
  permission String
  granted   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, groupId, permission])
  @@index([accountId])
  @@index([groupId])
  @@index([permission])
  @@map("account_permissions")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?  @unique
  passwordHash String?
  avatar       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupMemberships UserGroupMember[]

  @@map("users")
}

model UserGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  color       String   @default("#6366f1")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     UserGroupMember[]
  permissions GroupPermission[]

  @@unique([name])
  @@map("user_groups")
}

model UserGroupMember {
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userGroupId Int
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([userId, userGroupId])
  @@index([userId])
  @@index([userGroupId])
  @@map("user_group_members")
}

model GroupPermission {
  id          Int      @id @default(autoincrement())
  userGroupId Int
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  permission  String
  accountId   Int?
  granted     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userGroupId, permission, accountId])
  @@index([userGroupId])
  @@index([permission])
  @@map("group_permissions")
}
